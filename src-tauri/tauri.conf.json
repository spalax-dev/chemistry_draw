{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chemistry-draw",
  "version": "0.1.0",
  "identifier": "dev.spalax.ChemistryDraw",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chemistry Draw",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "externalBin": [
      "../target/release/indigo-server"
    ],
    "resources": {
      "lib/**/*": "lib/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Science",
    "shortDescription": "Desktop wrapper of the Ketcher chemical structure editor",
    "longDescription": "Chemistry Draw is an unofficial desktop wrapper of Ketcher (Apache 2.0, EPAM Systems) for Linux. Draw molecules, reactions and macromolecules offline.",
    "licenseFile": "../LICENSE"
  }
}
